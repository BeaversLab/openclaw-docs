---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<details class="oc-accordion">
  {title && <summary>{title}</summary>}
  <div class="oc-accordion__content">
    <slot />
  </div>
</details>

<style>
  .oc-accordion {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-bg);
    overflow: hidden;
  }

  .oc-accordion + .oc-accordion {
    margin-top: 0.75rem;
  }

  .oc-accordion summary {
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    padding: 1rem 1.25rem;
    background: var(--sl-color-gray-6);
  }

  .oc-accordion summary::-webkit-details-marker {
    display: none;
  }

  .oc-accordion__content {
    padding: 1rem 1.25rem;
  }
</style>
