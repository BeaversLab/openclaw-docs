---
const title = Astro.locals.starlightRoute.entry.data.title;
---

<h1 id="_top" class="sl-initial-anchor">{title}</h1>

<style>
	@layer starlight.core {
		.sl-initial-anchor {
			position: absolute;
			inline-size: 1px;
			block-size: 1px;
			margin: -1px;
			padding: 0;
			overflow: hidden;
			clip: rect(0 0 0 0);
			clip-path: inset(50%);
			white-space: nowrap;
			border: 0;
		}
	}
</style>
