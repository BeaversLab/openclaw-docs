---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Page Not Found</title>
		<style>
			:root {
				color-scheme: dark;
				font-family: system-ui, sans-serif;
			}

			body {
				margin: 0;
				min-height: 100vh;
				display: grid;
				place-items: center;
				background: #0f172a;
				color: #e5e7eb;
			}

			main {
				text-align: center;
				padding: 2rem;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: clamp(2rem, 6vw, 3rem);
			}

			p {
				margin: 0 0 1.5rem;
				color: #cbd5e1;
			}

			a {
				display: inline-block;
				padding: 0.75rem 1.1rem;
				border-radius: 999px;
				background: #38bdf8;
				color: #082f49;
				text-decoration: none;
				font-weight: 700;
			}
		</style>
	</head>
	<body>
		<main>
			<h1>404</h1>
			<p>Page not found.</p>
			<a href="/">Return to home</a>
		</main>
	</body>
</html>
