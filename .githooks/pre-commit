#!/bin/sh
set -eu

# Collect staged files for Prettier formatting
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(md|mdx|json|yaml|yml|json5)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "Formatting staged files..."
  # Run prettier through pnpm to use the project's version and config
  pnpm prettier --write $STAGED_FILES

  # Fix links and imports in MDX/MD files
  STAGED_DOCS=$(echo "$STAGED_FILES" | grep -E '\.(md|mdx)$' || true)
  if [ -n "$STAGED_DOCS" ]; then
    echo "Fixing links and imports in staged docs..."
    node scripts/fix-locale-links.js $STAGED_DOCS
  fi

  # Restage the formatted and fixed files
  git add $STAGED_FILES
fi
